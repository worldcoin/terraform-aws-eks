# Gateway API — import blocks for migrating from ArgoCD/Helm to Terraform.
#
# Steps:
#   1. Copy this file into your ROOT module (next to your module "eks" block)
#   2. Replace "module.eks" below with your actual module name (sed/find-replace)
#   3. Adjust _gw_do_import_ext/_int to match your gateway_api_*_enabled flags
#   4. Run: terraform plan  (verify imports + changes)
#   5. Run: terraform apply (imports existing, creates new resources)
#   6. Remove the gateway-api-* Helm charts from ArgoCD
#   7. Delete this file (next apply will destroy orphaned backendlbpolicies CRD)

locals {
  _gw_do_import     = true
  _gw_do_import_ext = true # set to false if gateway_api_external_enabled = false
  _gw_do_import_int = true # set to false if gateway_api_internal_enabled = false
}

# =============================================================================
# Orphaned CRD cleanup — backendlbpolicies was removed from Gateway API after
# v1.2.0. Importing it here means deleting this file will destroy it.
# =============================================================================

resource "kubernetes_manifest" "backendlbpolicies_cleanup" {
  manifest = {
    apiVersion = "apiextensions.k8s.io/v1"
    kind       = "CustomResourceDefinition"
    metadata = {
      name = "backendlbpolicies.gateway.networking.k8s.io"
    }
    spec = {
      group = "gateway.networking.k8s.io"
      names = {
        kind     = "BackendLBPolicy"
        listKind = "BackendLBPolicyList"
        plural   = "backendlbpolicies"
        singular = "backendlbpolicy"
      }
      scope = "Namespaced"
      versions = [{
        name    = "v1alpha2"
        served  = true
        storage = true
        subresources = {
          status = {}
        }
      }]
    }
  }

  computed_fields = ["spec.conversion", "spec.versions"]

  field_manager {
    force_conflicts = true
  }
}

import {
  for_each = local._gw_do_import ? toset(["do"]) : toset([])
  to       = kubernetes_manifest.backendlbpolicies_cleanup
  id       = "apiVersion=apiextensions.k8s.io/v1,kind=CustomResourceDefinition,name=backendlbpolicies.gateway.networking.k8s.io"
}

# =============================================================================
# CRDs — import those that already exist from previous Helm deployment.
# New CRDs (listenersets) will be created fresh.
# =============================================================================

import {
  for_each = local._gw_do_import ? toset([
    "CustomResourceDefinition/backendtlspolicies.gateway.networking.k8s.io",
    "CustomResourceDefinition/gatewayclasses.gateway.networking.k8s.io",
    "CustomResourceDefinition/gateways.gateway.networking.k8s.io",
    "CustomResourceDefinition/grpcroutes.gateway.networking.k8s.io",
    "CustomResourceDefinition/httproutes.gateway.networking.k8s.io",
    "CustomResourceDefinition/referencegrants.gateway.networking.k8s.io",
    "CustomResourceDefinition/tcproutes.gateway.networking.k8s.io",
    "CustomResourceDefinition/tlsroutes.gateway.networking.k8s.io",
    "CustomResourceDefinition/udproutes.gateway.networking.k8s.io",
    "CustomResourceDefinition/xbackendtrafficpolicies.gateway.networking.x-k8s.io",
    "CustomResourceDefinition/xmeshes.gateway.networking.x-k8s.io",
    "CustomResourceDefinition/listenerruleconfigurations.gateway.k8s.aws",
    "CustomResourceDefinition/loadbalancerconfigurations.gateway.k8s.aws",
    "CustomResourceDefinition/targetgroupconfigurations.gateway.k8s.aws",
  ]) : toset([])
  to = module.eks.kubernetes_manifest.gateway_api_crds[each.value]
  id = "apiVersion=apiextensions.k8s.io/v1,kind=CustomResourceDefinition,name=${split("/", each.value)[1]}"
}

# =============================================================================
# GatewayClass
# =============================================================================

import {
  for_each = local._gw_do_import ? toset(["do"]) : toset([])
  to       = module.eks.kubernetes_manifest.gateway_class_alb[0]
  id       = "apiVersion=gateway.networking.k8s.io/v1,kind=GatewayClass,name=aws-alb"
}

import {
  for_each = local._gw_do_import ? toset(["do"]) : toset([])
  to       = module.eks.kubernetes_manifest.gateway_class_nlb[0]
  id       = "apiVersion=gateway.networking.k8s.io/v1,kind=GatewayClass,name=aws-nlb"
}

